{
    "name": "rhyltonn/vagas-xp-fields",
    "description": "A Laravel Nova field.",
    "keywords": [
        "laravel",
        "nova"
    ],
    "license": "MIT",
    "require": {
        "php": "^7.3|^8.0"
    },
    "autoload": {
        "psr-4": {
            "Rhyltonn\\VagasXpFields\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "nova": "LA93yK1DAqukjzR7GuUGRmmFh6iyulOz66TCwNUBVQKYYrPfgh",
            "providers": [
                "Rhyltonn\\VagasXpFields\\FieldServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
